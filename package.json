{
  "name": "tsign-callback-dispatcher",
  "version": "1.0.0",
  "description": "腾讯电子签回调分发服务",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "test:docker:up": "cd docker/test && ./test-env.sh up",
    "test:docker:down": "cd docker/test && ./test-env.sh down",
    "test:docker:rebuild": "cd docker/test && ./test-env.sh rebuild",
    "test:docker:status": "cd docker/test && ./test-env.sh status",
    "test:docker:logs": "cd docker/test && ./test-env.sh logs",
    "test:docker:health": "cd docker/test && ./test-env.sh health",
    "test:docker:reset": "cd docker/test && ./test-env.sh reset",
    "test:docker:clean": "cd docker/test && ./test-env.sh clean",
    "test:docker:send": "cd docker/test && ./test-env.sh send",
    "test:docker:check": "cd docker/test && ./test-env.sh check",
    "test:docker:clear": "cd docker/test && ./test-env.sh clear",
    "dev": "./dev.sh start",
    "dev:stop": "./dev.sh stop",
    "dev:restart": "./dev.sh restart",
    "dev:status": "./dev.sh status",
    "dev:logs": "./dev.sh logs",
    "dev:logs:frontend": "./dev.sh logs frontend"
  }
}
